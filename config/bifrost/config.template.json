{
  "$schema": "https://www.getbifrost.ai/schema",
  "client": {
    "drop_excess_requests": false
  },
  "config_store": {
    "config": {
      "path": "./config.db"
    },
    "enabled": true,
    "type": "sqlite"
  },
  "governance": {
    "routing_rules": [
      {
        "cel_expression": "headers[\"x-bf-task\"] == \"think\" || headers[\"x-bf-route\"] == \"think\"",
        "description": "Route high-reasoning tasks to ZAI's strongest coding plan model.",
        "enabled": true,
        "fallbacks": [
          "zai-openai/glm-4.7"
        ],
        "id": "route-think",
        "name": "Think Tasks",
        "priority": 10,
        "scope": "global",
        "targets": [
          {
            "model": "glm-5.1",
            "provider": "zai-openai",
            "weight": 1
          }
        ]
      },
      {
        "cel_expression": "headers[\"x-bf-task\"] == \"long_context\" || headers[\"x-bf-route\"] == \"long_context\" || headers[\"x-bf-task\"] == \"longContext\" || headers[\"x-bf-route\"] == \"longContext\"",
        "description": "Prefer the strongest long-context model for explicitly labeled long-context work.",
        "enabled": true,
        "fallbacks": [
          "zai-openai/glm-4.7"
        ],
        "id": "route-long-context",
        "name": "Long Context Tasks",
        "priority": 20,
        "scope": "global",
        "targets": [
          {
            "model": "glm-5-turbo",
            "provider": "zai-openai",
            "weight": 1
          }
        ]
      },
      {
        "cel_expression": "headers[\"x-bf-task\"] == \"web_search\" || headers[\"x-bf-route\"] == \"web_search\" || headers[\"x-bf-task\"] == \"webSearch\" || headers[\"x-bf-route\"] == \"webSearch\"",
        "description": "Prefer the stronger model when the caller marks a browsing or search-heavy request.",
        "enabled": true,
        "fallbacks": [
          "zai-openai/glm-4.7"
        ],
        "id": "route-web-search",
        "name": "Web Search Tasks",
        "priority": 30,
        "scope": "global",
        "targets": [
          {
            "model": "glm-5-turbo",
            "provider": "zai-openai",
            "weight": 1
          }
        ]
      },
      {
        "cel_expression": "headers[\"x-bf-task\"] == \"image\" || headers[\"x-bf-route\"] == \"image\"",
        "description": "Route explicitly labeled multimodal or vision chat requests to ZAI vision models.",
        "enabled": true,
        "fallbacks": [
          "zai-openai/glm-4.5-air"
        ],
        "id": "route-image",
        "name": "Vision Tasks",
        "priority": 40,
        "scope": "global",
        "targets": [
          {
            "model": "GLM-4.5V",
            "provider": "zai-openai",
            "weight": 0.6
          },
          {
            "model": "GLM-4.6V",
            "provider": "zai-openai",
            "weight": 0.4
          }
        ]
      },
      {
        "cel_expression": "headers[\"x-bf-task\"] == \"background\" || headers[\"x-bf-route\"] == \"background\" || headers[\"x-bf-task\"] == \"cheap\" || headers[\"x-bf-route\"] == \"cheap\" || headers[\"x-bf-task\"] == \"high_throughput\" || headers[\"x-bf-route\"] == \"high_throughput\"",
        "description": "Keep low-priority background work on the cheaper ZAI model.",
        "enabled": true,
        "fallbacks": [
          "zai-openai/glm-4.5-air"
        ],
        "id": "route-background",
        "name": "Background Tasks",
        "priority": 50,
        "scope": "global",
        "targets": [
          {
            "model": "glm-4.7-flashx",
            "provider": "zai-openai",
            "weight": 1
          }
        ]
      }
    ]
  },
  "plugins": [
    {
      "config": {
        "cache_by_model": true,
        "cache_by_provider": true,
        "cleanup_on_shutdown": false,
        "dimension": 1,
        "ttl": "5m"
      },
      "enabled": true,
      "name": "semantic_cache"
    }
  ],
  "providers": {
    "anthropic": {
      "keys": [
        {
          "models": [
            "GLM-4.7",
            "GLM-4.5-Air",
            "GLM-4.5V",
            "GLM-4.6V"
          ],
          "name": "zai-anthropic-primary",
          "value": "env.ZAI_API_KEY",
          "weight": 1.0
        }
      ],
      "network_config": {
        "base_url": "https://api.z.ai/api/anthropic"
      }
    },
    "openai": {
      "keys": [
        {
          "models": [
            "gpt-5.4",
            "gpt-5.4-mini",
            "gpt-5.3-codex"
          ],
          "name": "openai-primary",
          "value": "env.OPENAI_API_KEY",
          "weight": 1.0
        }
      ],
      "network_config": {
        "base_url": "https://api.openai.com"
      }
    },
    "zai-openai": {
      "custom_provider_config": {
        "allowed_requests": {
          "chat_completion": true,
          "chat_completion_stream": true
        },
        "base_provider_type": "openai",
        "request_path_overrides": {
          "chat_completion": "/api/coding/paas/v4/chat/completions",
          "chat_completion_stream": "/api/coding/paas/v4/chat/completions"
        }
      },
      "keys": [
        {
          "models": [
            "GLM-5.1",
            "GLM-5-Turbo",
            "GLM-4.7",
            "GLM-4.5-Air"
          ],
          "name": "zai-openai-primary",
          "value": "env.ZAI_API_KEY",
          "weight": 1.0
        }
      ],
      "network_config": {
        "base_url": "https://api.z.ai"
      }
    }
  },
  "vector_store": {
    "config": {
      "addr": "localhost:6380"
    },
    "enabled": true,
    "type": "redis"
  }
}
