{
  "$schema": "https://www.getbifrost.ai/schema",
  "client": {
    "drop_excess_requests": false
  },
  "config_store": {
    "config": {
      "path": "./config.db"
    },
    "enabled": true,
    "type": "sqlite"
  },
  "governance": {
    "routing_rules": [
      {
        "cel_expression": "headers[\"x-bf-task\"] == \"think\" || headers[\"x-bf-route\"] == \"think\"",
        "description": "Route high-reasoning tasks to MiniMax's strongest text model.",
        "enabled": true,
        "fallbacks": [
          "minimax-openai/MiniMax-M2.7-highspeed"
        ],
        "id": "route-think",
        "name": "Think Tasks",
        "priority": 10,
        "scope": "global",
        "targets": [
          {
            "model": "MiniMax-M2.7",
            "provider": "minimax-openai",
            "weight": 1
          }
        ]
      },
      {
        "cel_expression": "headers[\"x-bf-task\"] == \"long_context\" || headers[\"x-bf-route\"] == \"long_context\" || headers[\"x-bf-task\"] == \"longContext\" || headers[\"x-bf-route\"] == \"longContext\"",
        "description": "Prefer the strongest MiniMax text model for explicitly labeled long-context work.",
        "enabled": true,
        "fallbacks": [
          "minimax-openai/MiniMax-M2.7-highspeed"
        ],
        "id": "route-long-context",
        "name": "Long Context Tasks",
        "priority": 20,
        "scope": "global",
        "targets": [
          {
            "model": "MiniMax-M2.7-highspeed",
            "provider": "minimax-openai",
            "weight": 1
          }
        ]
      },
      {
        "cel_expression": "headers[\"x-bf-task\"] == \"web_search\" || headers[\"x-bf-route\"] == \"web_search\" || headers[\"x-bf-task\"] == \"webSearch\" || headers[\"x-bf-route\"] == \"webSearch\"",
        "description": "Prefer MiniMax's stronger text model when the caller marks a browsing or search-heavy request.",
        "enabled": true,
        "fallbacks": [
          "minimax-openai/MiniMax-M2.7-highspeed"
        ],
        "id": "route-web-search",
        "name": "Web Search Tasks",
        "priority": 30,
        "scope": "global",
        "targets": [
          {
            "model": "MiniMax-M2.7-highspeed",
            "provider": "minimax-openai",
            "weight": 1
          }
        ]
      },
      {
        "cel_expression": "headers[\"x-bf-task\"] == \"image\" || headers[\"x-bf-route\"] == \"image\"",
        "description": "Deferred until a supported MiniMax multimodal adapter exists.",
        "enabled": false,
        "fallbacks": [
          "minimax-openai/MiniMax-M2.7"
        ],
        "id": "route-image",
        "name": "Vision Tasks",
        "priority": 40,
        "scope": "global",
        "targets": [
          {
            "model": "MiniMax-M2.7",
            "provider": "minimax-openai",
            "weight": 1
          }
        ]
      },
      {
        "cel_expression": "headers[\"x-bf-task\"] == \"background\" || headers[\"x-bf-route\"] == \"background\" || headers[\"x-bf-task\"] == \"cheap\" || headers[\"x-bf-route\"] == \"cheap\" || headers[\"x-bf-task\"] == \"high_throughput\" || headers[\"x-bf-route\"] == \"high_throughput\"",
        "description": "Keep low-priority background work on MiniMax's faster text model.",
        "enabled": true,
        "fallbacks": [
          "minimax-openai/MiniMax-M2.7-highspeed"
        ],
        "id": "route-background",
        "name": "Background Tasks",
        "priority": 50,
        "scope": "global",
        "targets": [
          {
            "model": "MiniMax-M2.7-highspeed",
            "provider": "minimax-openai",
            "weight": 1
          }
        ]
      }
    ]
  },
  "plugins": [
    {
      "config": {
        "cache_by_model": true,
        "cache_by_provider": true,
        "cleanup_on_shutdown": false,
        "dimension": 1,
        "ttl": "5m"
      },
      "enabled": true,
      "name": "semantic_cache"
    }
  ],
  "providers": {
    "minimax-openai": {
      "custom_provider_config": {
        "allowed_requests": {
          "chat_completion": true,
          "chat_completion_stream": true
        },
        "base_provider_type": "openai",
        "request_path_overrides": {
          "chat_completion": "/v1/chat/completions",
          "chat_completion_stream": "/v1/chat/completions"
        }
      },
      "keys": [
        {
          "models": [
            "MiniMax-M2.7",
            "MiniMax-M2.7-highspeed"
          ],
          "name": "minimax-openai-primary",
          "value": "env.MINIMAX_API_KEY",
          "weight": 1.0
        }
      ],
      "network_config": {
        "base_url": "https://api.minimax.io"
      }
    },
    "openai": {
      "keys": [
        {
          "models": [
            "gpt-5.4",
            "gpt-5.4-mini",
            "gpt-5.3-codex"
          ],
          "name": "openai-primary",
          "value": "env.OPENAI_API_KEY",
          "weight": 1.0
        }
      ],
      "network_config": {
        "base_url": "https://api.openai.com"
      }
    }
  },
  "vector_store": {
    "config": {
      "addr": "localhost:6380"
    },
    "enabled": true,
    "type": "redis"
  }
}
