{
  "dashboard": {
    "description": "Real-time monitoring for all WebSocket servers in the Mahavishnu ecosystem",
    "panels": [
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "mappings": {
              "result": {
                "color": "green",
                "text": "Up"
              },
              "value": 1
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red",
                  "text": "Down",
                  "value": 0
                },
                {
                  "color": "green",
                  "text": "Up",
                  "value": 1
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 0,
          "y": 0
        },
        "id": 1,
        "options": {
          "calculation": "lastNotNull",
          "colorMode": "background",
          "graphMode": "area",
          "reduceOptions": false
        },
        "targets": [
          {
            "expr": "sum(websocket_health{server=~\"$mahavishnu|dhara|akosha|crackerjack|excalidraw|fastblocks\"}) or vector(0)",
            "legendFormat": "{{server}}",
            "refId": "A"
          }
        ],
        "title": "WebSocket Server Overview",
        "type": "stat"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "fillOpacity": 0.1,
            "lineWidth": 2
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 6,
          "y": 0
        },
        "id": 2,
        "targets": [
          {
            "expr": "websocket_connections{server=~\"$mahavishnu|dhara|akosha|crackerjack|excalidraw|fastblocks\"}",
            "legendFormat": "{{server}}",
            "refId": "B"
          }
        ],
        "title": "Active Connections",
        "type": "graph"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "fillOpacity": 0.1,
            "lineWidth": 2
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        },
        "id": 3,
        "targets": [
          {
            "expr": "rate(websocket_messages_total{server=~\"$mahavishnu|dhara|akosha|crackerjack|excalidraw|fastblocks\"}[5m])",
            "legendFormat": "{{server}} - {{message_type}}",
            "refId": "C"
          }
        ],
        "title": "Message Rate",
        "type": "graph"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "fillOpacity": 0.1,
            "lineWidth": 2,
            "unit": "s"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        },
        "id": 4,
        "targets": [
          {
            "expr": "histogram_quantile(0.99, websocket_broadcast_duration_seconds{server=~\"$mahavishnu|dhara|akosha|crackerjack|excalidraw|fastblocks\"})",
            "legendFormat": "{{server}}",
            "refId": "D"
          }
        ],
        "title": "Broadcast Duration (p99)",
        "type": "graph"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "fillOpacity": 0.1,
            "lineWidth": 2
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        },
        "id": 5,
        "targets": [
          {
            "expr": "rate(websocket_errors_total{server=~\"$mahavishnu|dhara|akosha|crackerjack|excalidraw|fastblocks\"}[5m])",
            "legendFormat": "{{server}} - {{error_type}}",
            "refId": "E"
          }
        ],
        "title": "Error Rate",
        "type": "graph"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "continuous-GrYl"
            },
            "max": 10,
            "min": 0
          }
        },
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 0,
          "y": 9
        },
        "id": 6,
        "options": {
          "colorMode": "value",
          "graphMode": "none"
        },
        "targets": [
          {
            "expr": "websocket_connections{server=\"mahavishnu\"}",
            "legendFormat": "Connections",
            "refId": "mahavishnu-connections"
          },
          {
            "expr": "sum(rate(websocket_messages_total{server=\"mahavishnu\"}[5m]))",
            "legendFormat": "Msg Rate",
            "refId": "mahavishnu-rate"
          }
        ],
        "title": "Mahavishnu Details",
        "type": "stat"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 9
        },
        "id": 7,
        "options": {
          "showHeader": true
        },
        "targets": [
          {
            "expr": "websocket_health{server=~\"$mahavishnu|dhara|akosha|crackerjack|excalidraw|fastblocks\"}",
            "formatAs": "table",
            "legendFormat": "{{server}}",
            "refId": "health-matrix"
          }
        ],
        "title": "Server Health Matrix",
        "transformations": [
          {
            "id": "table-cell-color-background-transperancy"
          }
        ],
        "type": "table"
      }
    ],
    "refresh": "10s",
    "schemaVersion": 36,
    "tags": [
      "websocket",
      "mahavishnu",
      "monitoring",
      "real-time"
    ],
    "timezone": "UTC",
    "title": "WebSocket Ecosystem Monitoring",
    "version": "1.0.0"
  }
}
