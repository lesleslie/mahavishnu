{
  "dashboard": {
    "description": "Real-time monitoring for adaptive routing with StatisticalRouter, CostOptimizer, and A/B testing",
    "panels": [
      {
        "description": "Number of routing decisions made per adapter",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 0
        },
        "id": 1,
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "showLegend": true
          },
          "tooltip": {
            "mode": "multi"
          }
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "sum by (adapter) (mahavishnu_routing_decisions_total{server=\"mahavishnu\"})",
            "hide": false,
            "legendFormat": "{{adapter}}",
            "refId": "A"
          }
        ],
        "title": "Routing Decisions by Adapter",
        "type": "stat"
      },
      {
        "description": "Success rate for each adapter (calculated from success/failure counts)",
        "fieldConfig": {
          "defaults": {
            "decimals": 1,
            "max": 100,
            "min": 0,
            "unit": "percent"
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 0
        },
        "id": 2,
        "options": {
          "orientation": "auto",
          "reduceOptions": [
            {
              "calcs": [
                "lastNotNull"
              ],
              "fields": "",
              "values": false
            }
          ]
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "(\n  sum(mahavishnu_adapter_executions_total{server=\"mahavishnu\",status=\"success\"}) by (adapter)\n  /\n  sum(mahavishnu_adapter_executions_total{server=\"mahavishnu\"}) by (adapter)\n) * 100\n",
            "hide": false,
            "legendFormat": "{{adapter}}",
            "refId": "B"
          }
        ],
        "title": "Adapter Execution Success Rate",
        "type": "gauge"
      },
      {
        "description": "Latency percentiles for each adapter",
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        },
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 0,
          "y": 4
        },
        "id": 3,
        "options": {
          "legend": {
            "displayMode": "table",
            "showLegend": true
          }
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "histogram_quantile(0.50, sum(rate(mahavishnu_adapter_latency_seconds_bucket{server=\"mahavishnu\"}[5m])) by (adapter, le))",
            "hide": false,
            "legendFormat": "p50 - {{adapter}}",
            "refId": "C"
          },
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "histogram_quantile(0.95, sum(rate(mahavishnu_adapter_latency_seconds_bucket{server=\"mahavishnu\"}[5m])) by (adapter, le))",
            "hide": false,
            "legendFormat": "p95 - {{adapter}}",
            "refId": "D"
          },
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "histogram_quantile(0.99, sum(rate(mahavishnu_adapter_latency_seconds_bucket{server=\"mahavishnu\"}[5m])) by (adapter, le))",
            "hide": false,
            "legendFormat": "p99 - {{adapter}}",
            "refId": "E"
          }
        ],
        "title": "Adapter Latency Distribution",
        "type": "graph"
      },
      {
        "description": "Number of times routing fell back to alternative adapters",
        "gridPos": {
          "h": 3,
          "w": 4,
          "x": 8,
          "y": 4
        },
        "id": 4,
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "orientation": "auto"
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "sum(mahavishnu_routing_fallbacks_total{server=\"mahavishnu\"})",
            "hide": false,
            "refId": "F"
          }
        ],
        "title": "Total Fallback Events",
        "type": "stat"
      },
      {
        "description": "Distribution of how many adapters were tried before success",
        "gridPos": {
          "h": 5,
          "w": 6,
          "x": 0,
          "y": 10
        },
        "id": 5,
        "options": {
          "calculate": false,
          "cellGap": 2,
          "cellRadius": 0,
          "cellValues": {},
          "color": {
            "exponent": 0.5,
            "fill": "dark-orange",
            "mode": "spectrum",
            "reverse": false,
            "scale": "exponential",
            "scheme": "Oranges",
            "steps": 128
          },
          "exemplars": {
            "color": "rgba(255,0,255,255)"
          },
          "legend": {
            "showLegend": false
          },
          "rowsFrame": 8,
          "tooltip": {
            "show": true,
            "yHistogram": false
          },
          "yAxis": {
            "axisFormat": "short"
          }
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "sum(mahavishnu_routing_fallback_chain_length_bucket{server=\"mahavishnu\"}) by (le)",
            "hide": false,
            "refId": "G"
          }
        ],
        "title": "Fallback Chain Length Distribution",
        "type": "heatmap"
      },
      {
        "description": "Cumulative routing costs in USD",
        "fieldConfig": {
          "defaults": {
            "decimals": 4,
            "unit": "currencyUSD"
          }
        },
        "gridPos": {
          "h": 5,
          "w": 6,
          "x": 6,
          "y": 10
        },
        "id": 6,
        "options": {
          "legend": {
            "displayMode": "table",
            "showLegend": true
          }
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "sum(increase(mahavishnu_routing_cost_usd_total{server=\"mahavishnu\"}[5m])) by (adapter)",
            "hide": false,
            "legendFormat": "{{adapter}}",
            "refId": "H"
          }
        ],
        "title": "Routing Cost Over Time",
        "type": "graph"
      },
      {
        "description": "Histogram of routing costs per adapter",
        "gridPos": {
          "h": 5,
          "w": 8,
          "x": 0,
          "y": 15
        },
        "id": 7,
        "options": {
          "calculate": false,
          "cellGap": 2,
          "cellRadius": 0,
          "color": {
            "exponent": 0.5,
            "fill": "dark-blue",
            "mode": "spectrum",
            "reverse": false,
            "scale": "exponential",
            "scheme": "Blues",
            "steps": 128
          },
          "legend": {
            "showLegend": true
          }
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "sum(increase(mahavishnu_routing_cost_usd_distribution_bucket{server=\"mahavishnu\"}[5m])) by (le, adapter)",
            "hide": false,
            "refId": "I"
          }
        ],
        "title": "Cost Distribution by Adapter",
        "type": "heatmap"
      },
      {
        "description": "Current cost vs budget for each budget type",
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": 0
                },
                {
                  "color": "yellow",
                  "value": 10
                },
                {
                  "color": "red",
                  "value": 50
                }
              ]
            },
            "unit": "currencyUSD"
          }
        },
        "gridPos": {
          "h": 5,
          "w": 4,
          "x": 8,
          "y": 15
        },
        "id": 8,
        "options": {
          "orientation": "auto",
          "reduceOptions": [
            {
              "calcs": [
                "lastNotNull"
              ],
              "fields": "",
              "values": false
            }
          ],
          "text": {
            "titleSize": 12,
            "valueSize": 32
          }
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "mahavishnu_routing_cost_usd_current{server=\"mahavishnu\"}",
            "hide": false,
            "legendFormat": "{{budget_type}}",
            "refId": "J"
          }
        ],
        "title": "Current Budget Utilization",
        "type": "gauge"
      },
      {
        "description": "Number of budget alerts by severity",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 20
        },
        "id": 9,
        "options": {
          "colorMode": "background",
          "graphMode": "none"
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "sum by (severity) (increase(mahavishnu_budget_alerts_total{server=\"mahavishnu\"}[1h]))",
            "hide": false,
            "legendFormat": "{{severity}}",
            "refId": "K"
          }
        ],
        "title": "Budget Alert Count",
        "type": "stat"
      },
      {
        "description": "Current number of active A/B tests",
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": 0
                },
                {
                  "color": "blue",
                  "value": 1
                },
                {
                  "color": "orange",
                  "value": 5
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 20
        },
        "id": 10,
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "orientation": "auto"
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "mahavishnu_ab_tests_active{server=\"mahavishnu\"}",
            "hide": false,
            "refId": "L"
          }
        ],
        "title": "Active A/B Tests",
        "type": "stat"
      },
      {
        "description": "Time taken to make routing decisions",
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 8
        },
        "id": 11,
        "options": {
          "legend": {
            "displayMode": "table",
            "showLegend": true
          }
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "histogram_quantile(0.50, sum(rate(mahavishnu_routing_latency_seconds_bucket{server=\"mahavishnu\"}[5m])) by (le))",
            "hide": false,
            "legendFormat": "p50",
            "refId": "M"
          },
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "histogram_quantile(0.95, sum(rate(mahavishnu_routing_latency_seconds_bucket{server=\"mahavishnu\"}[5m])) by (le))",
            "hide": false,
            "legendFormat": "p95",
            "refId": "N"
          },
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "histogram_quantile(0.99, sum(rate(mahavishnu_routing_latency_seconds_bucket{server=\"mahavishnu\"}[5m])) by (le))",
            "hide": false,
            "legendFormat": "p99",
            "refId": "O"
          }
        ],
        "title": "Routing Decision Latency",
        "type": "graph"
      },
      {
        "description": "Routing decisions by task type",
        "gridPos": {
          "h": 5,
          "w": 6,
          "x": 0,
          "y": 24
        },
        "id": 12,
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "showLegend": true,
            "values": [
              "value",
              "percent"
            ]
          },
          "tooltip": {
            "mode": "single",
            "sort": "none"
          }
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "sum by (task_type) (mahavishnu_routing_decisions_total{server=\"mahavishnu\"})",
            "hide": false,
            "refId": "P"
          }
        ],
        "title": "Task Type Distribution",
        "type": "piechart"
      },
      {
        "alert": {
          "conditions": [
            {
              "evaluator": {
                "params": [
                  1
                ],
                "type": "lt"
              },
              "operator": {
                "type": "and"
              },
              "query": {
                "params": [
                  "Q",
                  "5m",
                  "now"
                ]
              },
              "reducer": {
                "type": "avg"
              },
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "handler": 1,
          "name": "Adapter Unhealthy",
          "noDataState": "no_data",
          "notifications": []
        },
        "description": "Health status of all registered adapters",
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "options": {
                  "0": {
                    "color": "red",
                    "text": "Unhealthy"
                  },
                  "1": {
                    "color": "green",
                    "text": "Healthy"
                  }
                },
                "type": "value"
              }
            ],
            "max": 1,
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red",
                  "value": 0
                },
                {
                  "color": "green",
                  "value": 1
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 5,
          "w": 6,
          "x": 6,
          "y": 24
        },
        "id": 13,
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "orientation": "auto",
          "text": {
            "titleSize": 12,
            "valueSize": 24
          }
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "mahavishnu_adapter_health{server=\"mahavishnu\"}",
            "hide": false,
            "legendFormat": "{{adapter_name}} - {{status}}",
            "refId": "Q"
          }
        ],
        "title": "Adapter Health Status",
        "type": "stat"
      },
      {
        "description": "Health status changes over time",
        "fieldConfig": {
          "defaults": {
            "max": 1,
            "min": 0
          }
        },
        "gridPos": {
          "h": 5,
          "w": 12,
          "x": 0,
          "y": 29
        },
        "id": 14,
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "showLegend": true
          }
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "sum by (adapter_name) (mahavishnu_adapter_health{server=\"mahavishnu\"})",
            "hide": false,
            "legendFormat": "{{adapter_name}}",
            "refId": "R"
          }
        ],
        "title": "Adapter Health Timeline",
        "type": "graph"
      }
    ],
    "refresh": "10s",
    "schemaVersion": 35,
    "tags": [
      "mahavishnu",
      "routing",
      "adaptive",
      "monitoring"
    ],
    "timezone": "UTC",
    "title": "Mahavishnu Adaptive Routing Monitoring",
    "uid": "mahavishnu-routing-monitoring",
    "version": "0.0.1"
  }
}
