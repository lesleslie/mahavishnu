{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/bodai-activity-post-tool-use.py",
            "type": "command"
          }
        ],
        "matcher": "mcp__*"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/bodai-activity-subscriber.py session-end",
            "type": "command"
          },
          {
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/worktree-session-isolation.py session-end",
            "type": "command"
          }
        ],
        "matcher": "end"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/bodai-activity-subscriber.py session-start",
            "type": "command"
          },
          {
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/worktree-session-isolation.py session-start",
            "type": "command"
          }
        ],
        "matcher": "startup"
      }
    ]
  },
  "permissions": {
    "deny": [
      "Read(./.backups/**)",
      "Read(./.archive/**)",
      "Read(./docs/archive/**)",
      "Read(./.claude/backups/**)",
      "Read(./.claude/agents/.a2a_enrollment/**)",
      "Read(./.claude/agents/**/*.backup*)",
      "Read(./.claude/commands/**/*.backup*)",
      "Read(./.claude/skills/.archive/**)",
      "Read(./.claude/skills/*.backup)",
      "Read(./.claude/skills/*.backup.json)",
      "Read(./.claude/agents/*.backup)",
      "Read(./.claude/agents/*.backup.json)",
      "Read(./.claude/commands/**/*.backup)",
      "Read(./.claude/commands/**/*.backup.json)"
    ]
  }
}
